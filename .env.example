# ── Database ──────────────────────────────────────────────────────────────────
# Same MongoDB Atlas cluster as main SocialHub Engine (or separate DB)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/browser-farm

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── API Security ──────────────────────────────────────────────────────────────
# Simple key to protect the dashboard + API
# Set the same key in SocialHub Engine env so it can call /api/farm/ready
API_KEY=your-secret-farm-key

# ── SocialHub Engine connection ───────────────────────────────────────────────
# Only needed if using proxyMode=engine (pulling proxies from the main engine)
ENGINE_URL=https://your-socialhub-engine.railway.app
ENGINE_API_KEY=your-engine-api-key
