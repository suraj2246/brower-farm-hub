# Engine Environment Variables
# Copy this to .env and fill in values

# MongoDB — can share with SocialHub or use separate DB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/socialhub-engine

# Engine API Key — SocialHub uses this to call the engine
# Generate a strong random string: openssl rand -hex 32
ENGINE_API_KEY=your-secret-engine-api-key-here

# Port
PORT=4000

# Anthropic AI (for scoring)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SocialHub backend URL (engine calls back when jobs complete)
SOCIALHUB_URL=https://socialhub-backend-production.up.railway.app
